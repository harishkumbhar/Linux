---
- name: RHEL 9 Daily Health Check
  hosts: all
  become: yes
  gather_facts: yes
  vars:
    report_file: "/var/log/rhel9_health_check.log"

  tasks:
    - name: Create or clear the daily report file
      ansible.builtin.copy:
        content: "--- RHEL 9 System Health Report - {{ ansible_date_time.date }} ---\n\n"
        dest: "{{ report_file }}"
        mode: '0644'

    - name: 1. Gather System Uptime
      ansible.builtin.shell: uptime
      register: uptime_out

    - name: 2. Check Memory Utilization
      ansible.builtin.shell: free -h
      register: memory_out

    - name: 3. Check Disk Space Usage
      ansible.builtin.shell: df -hP
      register: disk_out

    - name: 4. Check CPU Load Average
      ansible.builtin.shell: top -bn1 | grep "load average"
      register: cpu_out

    - name: 5. List Failed System Services
      ansible.builtin.shell: systemctl --state=failed --no-legend
      register: services_out

    - name: Append Uptime to Log
      ansible.builtin.lineinfile:
        path: "{{ report_file }}"
        line: "UPTIME:\n{{ uptime_out.stdout }}\n"
        insertafter: EOF

    - name: Append Memory to Log
      ansible.builtin.lineinfile:
        path: "{{ report_file }}"
        line: "MEMORY USAGE:\n{{ memory_out.stdout }}\n"
        insertafter: EOF

    - name: Append Disk Space to Log
      ansible.builtin.lineinfile:
        path: "{{ report_file }}"
        line: "DISK SPACE:\n{{ disk_out.stdout }}\n"
        insertafter: EOF

    - name: Append CPU Load to Log
      ansible.builtin.lineinfile:
        path: "{{ report_file }}"
        line: "CPU LOAD AVERAGE:\n{{ cpu_out.stdout }}\n"
        insertafter: EOF

    - name: Append Failed Services to Log
      ansible.builtin.lineinfile:
        path: "{{ report_file }}"
        line: "FAILED SERVICES:\n{{ services_out.stdout | default('None', true) }}\n"
        insertafter: EOF

    - name: Display completion message
      ansible.builtin.debug:
        msg: "Health check completed. Report written to {{ report_file }}"
