---
- name: Completely Uninstall Splunk Universal Forwarder
  hosts: splunk_forwarders
  become: yes
  vars:
    splunk_home: "/opt/splunkforwarder"
    splunk_user: "splunk"
    splunk_group: "splunk"

  tasks:
    - name: Check if Splunk is currently running
      ansible.builtin.command:
        cmd: "{{ splunk_home }}/bin/splunk status"
      register: splunk_status
      failed_when: false
      changed_when: false

    - name: Stop Splunk service if running
      ansible.builtin.command:
        cmd: "{{ splunk_home }}/bin/splunk stop"
      become: yes
      become_user: "{{ splunk_user }}"
      when: "'splunkd is running' in splunk_status.stdout"
      failed_when: false

    - name: Disable Splunk boot-start to remove systemd scripts
      ansible.builtin.command:
        cmd: "{{ splunk_home }}/bin/splunk disable boot-start"
      failed_when: false

    - name: Uninstall Splunk Forwarder package
      ansible.builtin.dnf: # Use ansible.builtin.apt for Debian/Ubuntu
        name: splunkforwarder
        state: absent

    - name: Remove Splunk installation directory completely
      ansible.builtin.file:
        path: "{{ splunk_home }}"
        state: absent

    - name: Remove remaining systemd service artifacts if any exist
      ansible.builtin.file:
        path: "/etc/systemd/system/SplunkForwarder.service"
        state: absent
      notify: Reload systemd daemon

    - name: Remove systemd symlinks
      ansible.builtin.file:
        path: "/etc/systemd/system/multi-user.target.wants/SplunkForwarder.service"
        state: absent
      notify: Reload systemd daemon

    - name: Remove ACL permissions for splunk user on /var/log/
      ansible.builtin.command:
        cmd: "setfacl -x u:{{ splunk_user }} /var/log/"
      failed_when: false

  handlers:
    - name: Reload systemd daemon
      ansible.builtin.systemd:
        daemon_reload: yes
